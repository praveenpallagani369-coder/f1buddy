{
  "crons": [
    {
      "path": "/api/reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/ai-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/cleanup-conversations",
      "schedule": "0 3 * * 0"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "framework": "nextjs"
}
