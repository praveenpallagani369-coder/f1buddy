# ============================================================
# VisaBuddy Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (FREE — supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DATABASE_URL — IMPORTANT: use the POOLER connection string, NOT direct.
# In Supabase: Settings → Database → Connection string → Transaction mode (port 6543)
# Direct (port 5432) hits the 15-connection free tier limit fast.
# Pooler (port 6543) supports thousands of concurrent serverless connections.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Groq AI (FREE — console.groq.com → API Keys)
GROQ_API_KEY=gsk_your-groq-key

# Stripe (FREE until first sale — dashboard.stripe.com → API Keys)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Create these in Stripe Dashboard → Products → Add Product
# Monthly: $4.99/month recurring — copy the Price ID (starts with price_)
STRIPE_PRICE_MONTHLY_ID=price_your-monthly-price-id
# Yearly: $39.99/year recurring — copy the Price ID (starts with price_)
STRIPE_PRICE_YEARLY_ID=price_your-yearly-price-id

# Resend Email (FREE 100/day — resend.com → API Keys)
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@visabuddy.app

# Encryption for SEVIS ID, passport numbers (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-key-here
# Salt for key derivation — generate with: openssl rand -hex 32
# WARNING: Changing this after launch requires re-encrypting all existing PII in the database.
ENCRYPTION_SALT=your-64-char-hex-salt-here

# Cron job secret for /api/reminders and /api/cron/* (generate with: openssl rand -hex 16)
# Vercel sends this automatically as Bearer token from vercel.json crons.
CRON_SECRET=your-cron-secret

# Push Notifications (Web Push / VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# Copy the output into the vars below.
# NOTE: public key must be prefixed NEXT_PUBLIC_ so the browser hook can access it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Use mailto: with your contact email
VAPID_SUBJECT=mailto:hello@visabuddy.app

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flags
# Set to "false" to hide biometric login button (WebAuthn requires migration 007 to be run first)
NEXT_PUBLIC_ENABLE_BIOMETRIC=true

# Dev only — set to "true" to enable /api/seed endpoint (admin users only)
# ALLOW_SEED=true
